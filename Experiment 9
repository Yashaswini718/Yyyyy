import numpy as np

# Create arrays
a = np.array([1, 2, 3])
b = np.array([4, 5, 6])

print("Array A:", a)
print("Array B:", b)

# Operations
print("Addition:", a + b)
print("Multiplication:", a * b)

# 2D Array
matrix = np.array([[1, 2], [3, 4]])
print("Matrix:\n", matrix)

# Transpose
print("Transpose:\n", matrix.T)
